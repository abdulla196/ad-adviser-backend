# =============================================
# AD ADVISER BACKEND - Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# =============================================

PORT=5000
NODE_ENV=development

# ---------------------------
# META (Facebook & Instagram)
# Get from: https://developers.facebook.com
# ---------------------------
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_long_lived_access_token
META_AD_ACCOUNT_ID=act_your_ad_account_id

# Business type apps using Facebook Login for Business should create a
# configuration in Meta App Dashboard and set the configuration ID here.
# When META_CONFIG_ID is set, Meta uses the permissions defined in that
# configuration instead of the scope list below.
META_CONFIG_ID=

# Keep advanced Meta permissions disabled until your app is approved for them.
META_ENABLE_ADVANCED_SCOPES=false
# Meta OAuth scopes — basic login works with public_profile,email.
# Add pages_show_list / ads_read only after they are enabled for your app and
# META_ENABLE_ADVANCED_SCOPES is set to true.
META_OAUTH_SCOPES=public_profile,email

# ---------------------------
# TIKTOK
# Get from: https://business.tiktok.com/portal
# ---------------------------
TIKTOK_APP_ID=your_tiktok_app_id
TIKTOK_APP_SECRET=your_tiktok_app_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_ADVERTISER_ID=your_tiktok_advertiser_id

# ---------------------------
# SNAPCHAT
# Get from: https://businesshelp.snapchat.com
# ---------------------------
SNAPCHAT_CLIENT_ID=your_snapchat_client_id
SNAPCHAT_CLIENT_SECRET=your_snapchat_client_secret
SNAPCHAT_ACCESS_TOKEN=your_snapchat_access_token
SNAPCHAT_AD_ACCOUNT_ID=your_snapchat_ad_account_id

# ---------------------------
# GOOGLE ADS
# Get from: https://console.developers.google.com
# ---------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_DEVELOPER_TOKEN=your_google_developer_token
GOOGLE_CUSTOMER_ID=your_google_customer_id

# ---------------------------
# OAUTH REDIRECT URIs
# ---------------------------
FRONTEND_URL=http://localhost:3000
META_REDIRECT_URI=http://localhost:5000/api/auth/meta/callback
TIKTOK_REDIRECT_URI=http://localhost:5000/api/auth/tiktok/callback
SNAPCHAT_REDIRECT_URI=http://localhost:5000/api/auth/snapchat/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ---------------------------
# SECURITY
# ---------------------------
API_KEY=your_secret_api_key_for_frontend
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
